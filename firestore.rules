rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isMediashock() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.matches('.*@mediashock[.]com[.]sg$');
    }

    match /{document=**} {
      allow read, write: if isMediashock();
    }
  }
}
